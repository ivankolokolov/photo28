# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here

# Database
DATABASE_URL=sqlite+aiosqlite:///./storage/bot.db

# Yandex Disk
YANDEX_DISK_TOKEN=your_yandex_disk_oauth_token

# Admin Panel
ADMIN_SECRET_KEY=your_secret_key_for_admin_panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password

# Storage paths
PHOTOS_DIR=./storage/photos
TEMP_DIR=./storage/temp

# Manager contact
MANAGER_USERNAME=your_manager_username

# Payment details (в мультитенантной версии берутся из записи студии)
PAYMENT_PHONE=+70000000000
PAYMENT_CARD=0000000000000000
PAYMENT_RECEIVER=Имя Получателя

# Тестовая БД (отдельная от рабочей!)
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/photo28_test
# Ключ шифрования секретов студий (сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=
